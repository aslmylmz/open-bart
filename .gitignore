# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.env
venv/
.venv/

# ── Node ──────────────────────────────────────────────────────────────────
node_modules/
.next/
dist/

# ── PyInstaller (frozen sidecar build artifacts) ──────────────────────────
build/
*.manifest

# ── Tauri (Rust shell build output + bundled sidecar binary) ──────────────
app/src-tauri/target/
app/src-tauri/gen/
app/src-tauri/binaries/

# ── Data (real participant data is NEVER committed) ───────────────────────
data/raw/
data/participants/
*.csv
# Allow synthetic data directory
!data/synthetic/
!data/synthetic/**

# ── Script output ─────────────────────────────────────────────────────────
output/

# ── Documentation build ───────────────────────────────────────────────────
docs/_build/

# ── LaTeX build artifacts (paper/) ────────────────────────────────────────
*.aux
*.bbl
*.blg
*.log
*.out
*.toc
*.synctex.gz
*.fdb_latexmk
*.fls

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
.claude/
